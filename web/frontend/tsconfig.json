{
  "compilerOptions": {
    // Language and Environment
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "preserve",

    // ============================================================
    // 🚀 Phase 1: 渐进式TypeScript迁移策略
    // ============================================================
    // 策略：允许JS/TS共存，逐步启用strict模式
    // 目标：TypeScript覆盖率从20% → 90%

    // Phase 1.4.1: 启用基础strict模式（仅针对.ts文件）
    "strict": true,  // ✅ Phase 1启用（配合checkJs: false）

    // 渐进式启用strict子选项（避免一次性大量错误）
    "noUnusedLocals": false,        // Phase 2启用
    "noUnusedParameters": false,   // Phase 2启用
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,         // ✅ Phase 1启用（最关键的类型检查）
    "strictNullChecks": true,      // ✅ Phase 1启用（空值检查）
    "strictFunctionTypes": false,   // Phase 2启用（较复杂）
    "strictBindCallApply": false,   // Phase 2启用
    "strictPropertyInitialization": false,  // Phase 2启用
    "noImplicitThis": true,        // ✅ Phase 1启用
    "alwaysStrict": true,

    // Additional Type Checking（Phase 2+启用）
    "noImplicitReturns": false,     // Phase 2启用
    "noUncheckedIndexedAccess": false,  // Phase 3启用
    "noImplicitOverride": false,   // Phase 2启用
    "exactOptionalPropertyTypes": false,  // Phase 3启用

    // Phase 1.4.2: JS/TS共存配置
    "allowJs": true,                // ✅ 允许导入.js文件
    "checkJs": false,               // ✅ 不检查.js文件（仅检查.ts）

    // Module Resolution
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "noEmit": true,

    // Path Mapping
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@types/*": ["src/types/*"]  // ✅ Phase 1.4.3: 共享类型目录
    },

    // Interop Constraints
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    // Vue Support
    "types": ["vite/client", "element-plus/global", "node"],

    // Additional Options
    "incremental": true,            // ✅ 增量编译（提升构建速度）
    "sourceMap": true,
    "noEmitOnError": false          // 🔧 紧急修复: 允许TypeScript错误但不阻止构建（2026-01-20）
  },

  // File Includes
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "src/**/*.js",                 // ✅ 包含.js文件（共存）
    "src/**/*.jsx",
    "src/types/**/*.ts"             // ✅ 包含共享类型定义
  ],

  // File Excludes
  "exclude": [
    "dist",
    "node_modules",
    "reports",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/api/types/generated-types.ts",  // 自动生成文件，类型冲突
    "src/api/types/extensions/**/*",     // 自动生成的扩展类型
    "src/api/types/additional-types.ts", // 自动生成的补充类型
    "src/api/advancedAnalysis.ts",       // API层低优先级文件
    "src/api/dataAdapter.ts",            // 依赖缺失的适配器
    "src/api/user.ts",                   // 用户API（低优先级）
    "src/api/strategy.ts",               // 策略API（低优先级）
    "src/api/trade.ts",                  // 交易API（低优先级）
    "src/api/monitoring.ts",             // 监控API（低优先级）
    "src/api/market.ts",                 // 市场API（低优先级）
    "src/components/market/ProKLineChart.vue",  // 暂时排除（Phase 2修复）
    "src/_entry-archive/**/*",              // 历史入口归档，不参与当前运行时 typecheck

    "src/views/artdeco-pages/settings/**/*",  // 设置页面（低优先级）
    "src/views/Phase4Dashboard.vue",     // 仪表板（低优先级）
    "src/views/monitor.vue",             // 监控页面（低优先级）
    "src/views/strategy/**/*",           // 策略相关（低优先级）
    "src/views/BacktestWizard.vue",      // 回测向导（低优先级）
    "src/views/stock-analysis/**/*",     // 股票分析（低优先级）
    "src/views/market/Etf.vue",          // ETF页面（低优先级）
    "src/views/demo/**/*",               // 演示代码（低优先级）
    "src/components/Charts/**/*",        // 图表组件（低优先级）
    "src/utils/chartExportUtils.ts",     // 图表导出工具（低优先级）
    "src/services/indicatorService.ts"   // 指标服务（低优先级）
  ],

  // Vue-specific compiler options (via vue-tsc)
  "vueCompilerOptions": {
    "target": 3.3
  }
}
