{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mystocks.local/schemas/myweb-audit/findings-schema.json",
  "title": "MyWeb Audit Finding",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "finding_id",
    "batch_id",
    "page",
    "source_role",
    "severity",
    "issue_type",
    "title",
    "trigger",
    "expected",
    "actual",
    "evidence",
    "repair_target",
    "can_fix_frontend",
    "shared_impact_candidate",
    "cross_page_impact",
    "status",
    "dedupe_key",
    "verification_surface",
    "verification"
  ],
  "properties": {
    "finding_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "batch_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "page": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route",
        "page_key",
        "route_class",
        "canonical_entry"
      ],
      "properties": {
        "route": {
          "type": "string",
          "minLength": 1
        },
        "page_key": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "route_class": {
          "type": "string",
          "enum": [
            "canonical-page",
            "detail-page",
            "compatibility-redirect"
          ]
        },
        "canonical_entry": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source_role": {
      "type": "string",
      "enum": [
        "functional-audit",
        "data-state-audit",
        "visual-artdeco-audit",
        "responsive-a11y-audit"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "Blocking",
        "High",
        "Medium",
        "Low"
      ]
    },
    "issue_type": {
      "type": "string",
      "enum": [
        "route",
        "interaction",
        "data-state",
        "visual",
        "responsive",
        "a11y",
        "dependency"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "steps"
      ],
      "properties": {
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "expected": {
      "type": "string",
      "minLength": 1
    },
    "actual": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "note"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "repair_target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "files"
      ],
      "properties": {
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "can_fix_frontend": {
      "type": "boolean"
    },
    "shared_impact_candidate": {
      "type": "boolean"
    },
    "cross_page_impact": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "deferred",
        "fixed",
        "blocked"
      ]
    },
    "dependency": {
      "type": [
        "string",
        "null"
      ]
    },
    "dedupe_key": {
      "type": "string",
      "pattern": "^/.+:[a-z-]+:[A-Za-z0-9_-]+$"
    },
    "verification_surface": {
      "type": "string",
      "enum": [
        "live-audit",
        "code-review-only"
      ]
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "complete",
        "notes"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "complete": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
