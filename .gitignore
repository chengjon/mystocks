# ========================================
# Excluded Files and Folders
# ========================================
# This file defines patterns for files/folders that should NOT be tracked by Git
# These are typically development artifacts, sensitive data, and project-irrelevant files

# ========================================
# SECURITY SENSITIVE FILES (CRITICAL)
# ========================================
# Environment Variables and Secrets
.env
.env.*
.env.*.local
.env.local
.env.production.local
!.env.example
!.env.development.example

# OpenCode config (may contain API keys)
opencode.json
tui.json
config/opencode.json
.mcp.json
.omc/
.config/opencode*.json*
.config/oh-my-opencode*.json*
.config/opencode/model/*.api_key
.config/opencode/model/model-catalog.json
.config/opencode/model/*.env
.config/opencode/model/*.base_url
.config/opencode/model/*.model
.config/opencode/model/README.md
.config/opencode/model/*.bak.*
opencode.json.bak.*
scripts/opencode/*.bak.*
tests/unit/*.bak.*

# Database Credentials and Backups
config/.env
config/.env.*
config/.env.backup*
!config/.env.example
!config/.env.data_sources.example

# Backend Environment Files (all except examples and testing)
web/backend/.env
web/backend/.env.*
!web/backend/.env.example
!web/backend/.env.testing  # Allowed - contains test credentials only

# Frontend Environment Files (all except examples)
web/frontend/.env
web/frontend/.env.*
!web/frontend/.env.mock  # Allowed - Mock data configuration

# API Keys and Certificates
*.key
*.pem
*.pfx
*.p12
*.crt
*.csr

# Sensitive Backups
.archive/sensitive-backups/
archive/legacy-dot-archive/sensitive-backups/
config/.env.backup*
*.backup
*.bak

# ========================================
# DEVELOPMENT ARTIFACTS (PROJECT-IRRELEVANT)
# ========================================
