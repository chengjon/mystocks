/build/
/dist/
/htmlcov/
**/.parcel-cache/

# Temporary Development Directories
/temp/
/tmp/
/temp_docs/
/opencodetmp/
/downloads/
.worktrees/

# Logging and Debug Files
*.log
dev-debug.log
logs/

# Benchmark Results
.benchmarks/

# Testing Artifacts
test-results/
.coverage
coverage.xml
htmlcov/
web/frontend/.lighthouseci/
web/frontend/dist-lighthouse/
web/frontend/\\wsl.localhost*
web/frontend/undefined:

# ========================================
# PROJECT-SPECIFIC TEMPORARY FILES
# ========================================
# ========================================
# DOT-DIRECTORY GOVERNANCE (2026-05-20)
# ========================================
# Rule: ALL dot-directories are ignored by default.
# Only exceptions listed below with ! prefixes are tracked.
# To add a new exception, add both the ! line and a comment explaining why.

# --- Ignore ALL dot-directories ---
.agent/
.amazonq/
.claude/
.claude-trace/
.codex/
.config/
.cursor/
.design/
.gemini/
.githooks/
.impeccable/
.kiro/
.migration/
.opencode/
.roo/
.shared/
.specify/
.taskmaster/
.windsurf/
.zencoder/

# --- Exception: .github/ (CI/CD, issue templates) ---
# No ignore rule — .github/ stays tracked

# --- Exception: .multi-cli-tasks/ (multi-CLI collaboration) ---
# No ignore rule — .multi-cli-tasks/ stays tracked

# --- Exception: .claude/ (project-shared hooks and config only) ---
!.claude/hooks/
!.claude/hooks/*.sh
!.claude/hooks/*.py
!.claude/hooks/*.md
!.claude/hooks/*.json
!.claude/settings.json
!.claude/skill-rules.json
!.claude/build-checker-python.json
!.claude/build-checker.json

# --- Exception: .planning/ (index files only) ---
.planning/*
!.planning/STATE.md
!.planning/PROJECT.md
!.planning/REQUIREMENTS.md
!.planning/ROADMAP.md
!.planning/MILESTONES.md
!.planning/config.json

# ========================================
# DATA AND CACHE FILES (DEVELOPMENT ONLY)
# ========================================
# CSV Files (test data, temporary exports)
*.csv

# Database Files
*.db
*.sqlite
*.sqlite3

# JSON Data (temporary, generated)
data/*.json

# Data Backups (auto-generated, development only)
data/backups/*
!data/backups/.gitkeep

# ========================================
# ARCHIVE AND OLD CODE (NOT FOR PRODUCTION)
# ========================================
.archive/
archive/

