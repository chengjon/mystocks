    "contact": {
      "name": "MyStocks Development Team",
      "email": "api@mystocks.com"
    },
    "license": {
      "name": "Proprietary",
      "url": "https://mystocks.com/license"
    }
  },
  "servers": [
    {
      "url": "https://api.mystocks.com/v1",
      "description": "Production server"
    },
    {
      "url": "http://localhost:8020/api/v1",
