  "components": {
    "schemas": {
      "DatabaseHealthResponse": {
        "type": "object",
        "properties": {
          "database_type": {"type": "string", "enum": ["postgresql", "tdengine"]},
          "connection_status": {"type": "string"},
          "response_time_ms": {"type": "number"},
          "active_connections": {"type": "integer"},
          "total_tables": {"type": "integer"},
          "last_health_check": {"type": "string", "format": "date-time"}
        },
        "required": ["database_type", "connection_status", "response_time_ms", "active_connections", "total_tables", "last_health_check"]
      },
      "DataRoutingRequest": {
        "type": "object",
        "properties": {
          "data_category": {"type": "string", "enum": ["market_data", "reference_data", "derived_data", "transaction_data", "metadata"]},
          "symbol": {"type": "string"},
          "date_range": {
            "type": "object",
            "properties": {
              "start_date": {"type": "string", "format": "date"},
              "end_date": {"type": "string", "format": "date"}
            }
          }
        },
        "required": ["data_category"]
      },
      "DataRoutingResponse": {
        "type": "object",
        "properties": {
          "route_selected": {"type": "string"},
          "estimated_records": {"type": "integer"},
          "query_complexity": {"type": "string"},
          "recommended_strategy": {"type": "string"}
        },
        "required": ["route_selected", "estimated_records", "query_complexity", "recommended_strategy"]
      },
      "MLStrategyType": {
        "type": "string",
        "enum": ["svm", "decision_tree", "naive_bayes", "lstm", "transformer"]
      },
      "StrategyTrainingRequest": {
        "type": "object",
        "properties": {
          "strategy_type": {"$ref": "#/components/schemas/MLStrategyType"},
          "symbol": {"type": "string", "pattern": "^\\d{6}$"},
          "start_date": {"type": "string", "format": "date"},
          "end_date": {"type": "string", "format": "date"},
          "parameters": {"type": "object"}
        },
        "required": ["strategy_type", "symbol", "start_date", "end_date"]
      },
      "StrategyTrainingResponse": {
        "type": "object",
        "properties": {
          "strategy_id": {"type": "string"},
          "strategy_type": {"type": "string"},
          "training_accuracy": {"type": "number"},
          "validation_score": {"type": "number"},
          "feature_importance": {"type": "object"},
          "training_duration_ms": {"type": "integer"},
          "model_size_bytes": {"type": "integer"}
        },
        "required": ["strategy_id", "strategy_type", "training_accuracy", "validation_score", "feature_importance", "training_duration_ms", "model_size_bytes"]
      },
      "StrategyPredictionRequest": {
        "type": "object",
        "properties": {
          "strategy_id": {"type": "string"},
          "symbol": {"type": "string", "pattern": "^\\d{6}$"},
          "prediction_horizon": {"type": "integer", "default": 5, "minimum": 1}
        },
        "required": ["strategy_id", "symbol"]
      },
