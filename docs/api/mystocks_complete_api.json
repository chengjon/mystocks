    "/mystocks/strategies": {
      "get": {
        "tags": ["Phase 2: ML Trading Strategies"],
        "summary": "List Available Strategies",
        "description": "获取可用策略列表 - Get list of available ML trading strategies",
        "operationId": "listStrategies",
