{
  "openapi": "3.1.0",
  "info": {
    "title": "MyStocks API - Complete Phase 1-5 Collection",
    "description": "Complete API collection for MyStocks Phase 1-5 features including Core Architecture, ML Trading Strategies, Real-time Trading, Enterprise Features, and Advanced Analytics. Complies with API Contract Management and OpenAPI 3.1.0 specifications.",
