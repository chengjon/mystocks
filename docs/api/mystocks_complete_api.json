    "/mystocks/technical-indicators": {
      "get": {
        "tags": ["Phase 2: ML Trading Strategies"],
        "summary": "Get Technical Indicators",
        "description": "计算技术指标 - Calculate technical indicators",
        "operationId": "getTechnicalIndicators",
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^\\d{6}$"
            },
            "description": "股票代码"
          },
          {
            "name": "indicators",
            "in": "query",
            "required": true,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["rsi", "macd", "bollinger", "sma", "ema"]
              }
            },
            "description": "指标名称列表"
          },
          {
            "name": "period",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 14,
              "minimum": 1
            },
            "description": "计算周期"
          }
        ],
        "responses": {
          "200": {
            "description": "指标计算成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "symbol": {"type": "string"},
                    "indicators": {"type": "object"},
                    "timestamp": {"type": "string", "format": "date-time"}
                  }
                }
              }
            }
          }
        }
      }
    },
