  "paths": {
    "/mystocks/health/database": {
      "get": {
        "tags": ["Phase 1: Core Architecture"],
        "summary": "Database Health Check",
        "description": "检查所有数据库的健康状态 - Check health status of all databases",
        "operationId": "getDatabaseHealth",
        "responses": {
          "200": {
            "description": "成功获取数据库健康状态",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DatabaseHealthResponse"
                  }
                }
              }
            }
          },
          "500": {
            "description": "服务器内部错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/mystocks/data/route": {
      "post": {
        "tags": ["Phase 1: Core Architecture"],
        "summary": "Data Routing Decision",
        "description": "根据数据特性和查询条件智能选择数据库路由 - Intelligent database routing based on data characteristics",
        "operationId": "getDataRoute",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DataRoutingRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功获取路由决策",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataRoutingResponse"
                }
              }
            }
          }
        }
      }
    },
