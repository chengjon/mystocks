{
  "$schema": "https://raw.githubusercontent.com/google-gemini/gemini-cli/main/schemas/settings.schema.json",
  "model": {
    "name": "gemini-3.1-pro"
  },
  "general": {
    "checkpointing": {
      "enabled": false
    }
  },
  "context": {
    "fileName": [
      "GEMINI.md"
    ]
  },
  "agents": {
    "overrides": {
      "codebase_investigator": {
        "enabled": false
      },
      "cli_help": {
        "enabled": false
      }
    }
  },
  "useWriteTodos": false,
  "mcp": {
    "excluded": [
      "chrome-devtools",
      "context7",
      "playwright",
      "puppeteer"
    ]
  }
}
