# ===================================
# MyStocks 环境配置模板
# ===================================
#
# 使用方法：
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 修改 .env 文件中的敏感信息
# 3. 确保 .env 文件已添加到 .gitignore
#
# 安全提醒：
# - 永远不要将包含真实密码的 .env 文件提交到版本控制
# - 生产环境请使用强密码和随机密钥
# - 定期轮换数据库密码和JWT密钥
#

# ===================================
# 必需配置项 (Required Settings)
# ===================================

# PostgreSQL 数据库配置 (必需)
POSTGRESQL_HOST=your_postgresql_host
POSTGRESQL_PORT=5432
POSTGRESQL_USER=your_postgresql_user
POSTGRESQL_PASSWORD=your_postgresql_password
POSTGRESQL_DATABASE=your_database_name

# JWT 认证密钥 (必需 - 生产环境请使用强随机密钥)
# 生成命令: openssl rand -hex 32
JWT_SECRET_KEY=your_jwt_secret_key_change_this_in_production

# CORS 配置 (必需 - 仅允许明确的前端域名)
# 开发环境: http://localhost:3020,http://localhost:3021
# 生产环境: https://your-frontend-domain.com
CORS_ORIGINS=http://localhost:3020,http://localhost:3021

# ===================================
# 可选配置项 (Optional Settings)
# ===================================

# Redis 配置 (可选 - 用于缓存、消息队列和 Celery)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1
REDIS_APP_CACHE_DB=1
REDIS_MONITORING_DB=0
REDIS_TOOLING_DB=0
REDIS_CELERY_BROKER_DB=0
REDIS_CELERY_RESULT_DB=1

# Celery 配置 (可选 - 未配置时将按 Redis role DB 自动回落)
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Mongo 兼容配置 (可选 - 当前主应用未直接依赖，但测试/容器口径仍保留)
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_ROOT_USERNAME=
MONGODB_ROOT_PASSWORD=
MONGODB_DATABASE=mystocks_docs
MONGODB_AUTH_SOURCE=admin

# 管理员初始密码 (可选 - 首次部署使用)
ADMIN_INITIAL_PASSWORD=your_admin_initial_password_here

# 日志级别 (可选 - 生产环境建议使用WARNING或ERROR)
LOG_LEVEL=INFO

# K线查询兜底开关 (可选 - true: 上游异常时返回内置fallback数据)
KLINE_FALLBACK_ENABLED=true

# 前后端端口统一配置
FRONTEND_PORT=3020
FRONTEND_BACKUP_PORT=3021
BACKEND_PORT=8020
BACKEND_BACKUP_PORT=8021

# ===================================
# 注释说明
# ===================================
#
# 必需配置项必须填写，否则应用无法启动
# 可选配置项有默认值，可以根据需要调整
#
# 环境变量优先级:
# 1. .env 文件中的值
# 2. 系统环境变量
# 3. Settings 类中的默认值
#
# 安全注意事项:
# - 所有密码和密钥必须使用强随机值
# - 生产环境禁止使用默认值
# - 定期轮换敏感凭据
# - .env 文件必须加入 .gitignore
#
# 日志级别说明:
# - DEBUG: 详细调试信息 (仅开发环境)
# - INFO: 一般信息 (默认)
# - WARNING: 警告信息
# - ERROR: 错误信息 (生产环境推荐)
