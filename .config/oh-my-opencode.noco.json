  "mcp": {
    "chrome-devtools": {
      "command": [
        "npx",
        "chrome-devtools-mcp@latest"
      ],
      "enabled": true,
      "type": "local"
    },
    "context7": {
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true,
      "type": "local"
    },
    "playwright": {
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true,
      "type": "local"
    },
    "puppeteer": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ],
      "enabled": true,
      "type": "local"
    },
    "web-reader": {
      "enabled": true,
      "headers": {
        "Authorization": "Bearer REDACTED_WEB_READER_TOKEN"
      },
      "type": "remote",
      "url": "https://open.bigmodel.cn/api/mcp/web_reader/mcp"
    }
  },
  "oh_my_opencode": {
    "agents": {
      "sisyphus": {
        "model": "{file:/opt/claude/mystocks_spec/.config/opencode/model_defaults/omo.sisyphus.model}",
        "description": "主协调器 - 整体任务规划和编排，深度推理",
        "capabilities": [
          "task_planning",
          "coordination",
          "deep_reasoning",
          "strategy_formulation"
        ]
      },
      "oracle": {
        "model": "{file:/opt/claude/mystocks_spec/.config/opencode/model_defaults/omo.oracle.model}",
        "description": "架构师 - 架构设计、代码审查、策略分析",
        "capabilities": [
          "architecture_design",
          "code_review",
          "strategy_analysis",
          "technical_decision"
        ]
      },
      "librarian": {
        "model": "{file:/opt/claude/mystocks_spec/.config/opencode/model_defaults/omo.librarian.model}",
        "description": "研究员 - 多仓库分析、文档查找、实现示例研究",
        "capabilities": [
          "multi_repo_analysis",
          "documentation_search",
          "implementation_research",
          "code_pattern_discovery"
        ]
      },
      "explore": {
        "model": "{file:/opt/claude/mystocks_spec/.config/opencode/model_defaults/omo.explore.model}",
        "description": "探索者 - 快速代码库探索和模式匹配",
        "capabilities": [
          "quick_exploration",
          "pattern_matching",
          "code_navigation",
          "fast_search"
        ]
      },
      "frontend": {
        "model": "{file:/opt/claude/mystocks_spec/.config/opencode/model_defaults/omo.frontend.model}",
        "description": "Frontend UI/UX - 构建精美前端界面",
        "capabilities": [
          "ui_design",
          "frontend_development",
          "user_experience",
          "responsive_design"
        ]
      },
      "document_writer": {
        "model": "{file:/opt/claude/mystocks_spec/.config/opencode/model_defaults/omo.document_writer.model}",
        "description": "Document Writer - 撰写技术文档",
        "capabilities": [
          "technical_writing",
          "documentation",
          "api_docs",
          "user_guides"
        ]
      },
      "multimodal_looker": {
        "model": "{file:/opt/claude/mystocks_spec/.config/opencode/model_defaults/omo.multimodal_looker.model}",
        "description": "Multimodal Looker - 分析 PDF、图像和图表",
        "capabilities": [
          "pdf_analysis",
          "image_understanding",
          "chart_analysis",
          "visual_content_processing"
        ]
      }
    },
    "background_task": {
      "providerConcurrency": {
        "opencode": 12,
        "cpap": 8,
        "cpap-oai": 4,
        "cpap-claude": 4,
        "cpap-mini": 6
      },
      "modelConcurrency": {
        "opencode/glm-4.7-free": 10,
        "opencode/kimi-k2.5-free": 10,
        "opencode/minimax-m2.1-free": 10,
        "opencode/gpt-5-nano": 10,
        "opencode/trinity-large-preview-free": 10,
        "cpap-claude/claude-opus-4-5": 2,
        "cpap-claude/claude-opus-4-6": 2,
        "cpap-oai/gpt-5.3": 2,
        "cpap-oai/gpt-5.3-codex": 2,
        "cpap/grok-4-heavy": 2,
        "cpap/grok-4.20-beta": 2
      }
    },
    "ralph_loop": {
      "enabled": true,
      "default_max_iterations": 100
    }
  }
}
