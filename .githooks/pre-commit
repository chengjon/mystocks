#!/bin/bash
# Pre-commit hook: directory governance gate
# Install: git config core.hooksPath .githooks

set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if [[ "${DISABLE_DIR_STRUCTURE_CHECK:-0}" == "1" ]]; then
  echo "⚠️  Directory governance check skipped via DISABLE_DIR_STRUCTURE_CHECK=1"
  exit 0
fi

if [[ "${SKIP:-}" == *"directory-governance"* ]]; then
  echo "⚠️  Directory governance check skipped via SKIP=directory-governance"
  exit 0
fi

echo "🔍 Running directory governance check on staged changes..."
bash "$PROJECT_ROOT/scripts/maintenance/check-structure.sh" "$PROJECT_ROOT" --staged --quiet

echo "✅ Directory governance check passed"
